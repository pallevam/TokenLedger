# =========================================================
# TokenLedger - Environment Configuration Template
# Copy to .env for local development. NEVER commit .env.
# In production, use GCP Secret Manager (see src/security/README.md)
# =========================================================

# --- Database ---
# Option A: Local SQLite (offline dev, no Supabase needed)
DATABASE_URL=sqlite:///./tracker.db

# Option B: Supabase Postgres (recommended)
# Get this from: Supabase Dashboard > Settings > Database > Connection string (URI tab)
# Use port 5432 (direct), NOT 6543 (PgBouncer) for SQLAlchemy
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.nwgyaxqtjvdnaewahaqx.supabase.co:5432/postgres

# --- Supabase SDK (for auth / realtime / storage features) ---
# Get these from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://nwgyaxqtjvdnaewahaqx.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Only for server-side admin ops

# --- GCP (Production) ---
# Set this to use GCP Secret Manager instead of env vars below.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# --- LLM API Keys (Local Dev Only) ---
# These are only used when GOOGLE_CLOUD_PROJECT is NOT set.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AI...

# --- Admin / Usage-API Keys (for the daily usage puller) ---
# Distinct from the API keys above — these read your org-wide usage history.
#
# OpenAI Admin key: https://platform.openai.com/settings/organization/admin-keys
OPENAI_ADMIN_KEY=sk-admin-...
# Anthropic Admin key: console.anthropic.com > Settings > Admin Keys
ANTHROPIC_ADMIN_KEY=sk-ant-admin-...
# Gemini: no first-party usage API; the puller is a stub that needs to be
# wired to BigQuery billing export or Cloud Monitoring. No key needed here.
